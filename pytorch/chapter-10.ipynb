   "source": [
    "import torch\n",
    "\n",
    "print(\"MPS: \", torch.backends.mps.is_available())\n",
    "\n",
    "size = (100000, 100000)\n",
    "M = torch.rand(size)\n",
    "%timeit M @ M.T\n",
    "\n",
    "M = torch.rand(size, device=\"mps\")\n",
    "%timeit M @ M.T\n"
   ],
